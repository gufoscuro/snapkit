# Copy this file to `.kamal/secrets` (gitignored) when running Kamal locally.
# In CI these values come from GitHub repo secrets — do NOT commit a populated
# `.kamal/secrets` file.
#
# Usage: cp .kamal/secrets.example .kamal/secrets, then fill in real values.

# GHCR pull/push credential. Locally, generate a Personal Access Token with
# `read:packages` (and `write:packages` if you push from your machine).
KAMAL_REGISTRY_PASSWORD=

# Backend API gateway URL injected into the running container at runtime.
# Must be named PUBLIC_API_GATEWAY — the app reads it via $env/dynamic/public.
PUBLIC_API_GATEWAY=
